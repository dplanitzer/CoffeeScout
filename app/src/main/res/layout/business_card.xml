<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/business_image"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:contentDescription="@string/hero_content_desc"
        android:scaleType="centerCrop"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:srcCompat="@tools:sample/backgrounds/scenic" />

    <TextView
        android:id="@+id/business_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Foo Cafe"
        android:textColor="@color/black"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="@+id/business_image"
        app:layout_constraintStart_toStartOf="@+id/business_image"
        app:layout_constraintTop_toBottomOf="@+id/business_image" />

    <TextView
        android:id="@+id/business_address"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="5th Ave"
        app:layout_constraintEnd_toEndOf="@+id/business_image"
        app:layout_constraintStart_toStartOf="@+id/business_image"
        app:layout_constraintTop_toBottomOf="@+id/business_name" />

    <com.example.coffeescout.view.YelpRatingBar
        android:id="@+id/business_rating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@+id/business_info"
        app:layout_constraintStart_toStartOf="@+id/business_image"
        app:layout_constraintTop_toTopOf="@+id/business_info" />

    <TextView
        android:id="@+id/business_info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:text="(123) | $$ | 100m"
        app:layout_constraintEnd_toEndOf="@+id/business_image"
        app:layout_constraintStart_toEndOf="@+id/business_rating"
        app:layout_constraintTop_toBottomOf="@+id/business_address" />

    <TextView
        android:id="@+id/business_hours"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Open 9:00AM - 10:00PM"
        app:layout_constraintEnd_toEndOf="@+id/business_image"
        app:layout_constraintStart_toStartOf="@+id/business_image"
        app:layout_constraintTop_toBottomOf="@+id/business_info" />

    <com.google.android.material.button.MaterialButton
        style="@style/BorderedButton"
        android:id="@+id/go_to_reviews"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:text="@string/read_reviews_title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@+id/business_image"
        app:layout_constraintTop_toBottomOf="@+id/business_hours" />

    <com.google.android.material.button.MaterialButton
        style="@style/BorderedButton"
        android:id="@+id/go_to_navigation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/navigation_title"
        app:layout_constraintEnd_toEndOf="@+id/business_image"
        app:layout_constraintTop_toBottomOf="@+id/business_hours" />

    <ImageView
        android:id="@+id/go_to_yelp"
        android:layout_width="72dp"
        android:layout_height="0dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="@+id/go_to_navigation"
        app:layout_constraintEnd_toStartOf="@+id/go_to_navigation"
        app:layout_constraintStart_toEndOf="@+id/go_to_reviews"
        app:layout_constraintTop_toTopOf="@+id/go_to_navigation"
        app:layout_constraintVertical_bias="0.0"
        app:srcCompat="@drawable/yelp_logo" />
</androidx.constraintlayout.widget.ConstraintLayout>